# =============================================================================
# NFL Predictor — local configuration
# Copy this file to .env and fill in your values. .env is gitignored.
# =============================================================================

# --- The Odds API (optional) -------------------------------------------------
# Free key at https://the-odds-api.com/ — betting lines factor is skipped if absent.
ODDS_API_KEY=

# --- Factor weights ----------------------------------------------------------
# These are your "secret sauce". The engine normalises whatever values you set
# so they don't need to sum to 1.0 — just express relative importance.
# Remove the betting lines weight (or set to 0) if you don't have an API key.
# Winner prediction weights
WEIGHT_RECENT_FORM=
WEIGHT_ATS_FORM=
WEIGHT_HEAD_TO_HEAD=
WEIGHT_BETTING_LINES=
WEIGHT_COACHING_MATCHUP=
WEIGHT_WEATHER=

# Cover prediction weights
COVER_WEIGHT_RECENT_FORM=
COVER_WEIGHT_ATS_FORM=
COVER_WEIGHT_HEAD_TO_HEAD=
COVER_WEIGHT_BETTING_LINES=
COVER_WEIGHT_COACHING_MATCHUP=
COVER_WEIGHT_WEATHER=

# Cover margin calibration (from optimiser run — update each season)
MARGIN_SLOPE=
MARGIN_INTERCEPT=

# Confidence clamping (optional — set ceiling < 100 to cap overconfident picks)
CONFIDENCE_FLOOR=
CONFIDENCE_CEILING=

# Factor tuning
RECENT_FORM_GAMES=
RECENT_FORM_DECAY=
ATS_FORM_GAMES=
H2H_GAMES=
COACHING_MIN_GAMES=

# --- Authentication ----------------------------------------------------------
# Required for EC2 deployment. Use AUTH_DISABLED=true for local dev instead.
#
# Generate a password hash (run once, store result here):
#   python3 -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('yourpassword'))"
#
# Generate a secret key:
#   openssl rand -hex 32
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Set to true to bypass all auth checks (localhost dev only — never set on EC2)
AUTH_DISABLED=true

# --- Scheduler (optional) ----------------------------------------------------
# All times are US Eastern (ET). Defaults match the values below.
# Mon 11pm: post-MNF results settled. Thu 10am: TNF prep. Sat 10am. Sun 7am: before early games.
SCHEDULER_MONDAY_HOUR=23
SCHEDULER_MONDAY_MINUTE=0
SCHEDULER_THURSDAY_HOUR=10
SCHEDULER_THURSDAY_MINUTE=0
SCHEDULER_SATURDAY_HOUR=10
SCHEDULER_SATURDAY_MINUTE=0
SCHEDULER_SUNDAY_HOUR=7
SCHEDULER_SUNDAY_MINUTE=0
