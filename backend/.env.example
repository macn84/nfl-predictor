# =============================================================================
# NFL Predictor — backend configuration template
# Copy this file to .env and fill in your values. .env is gitignored.
# =============================================================================

# --- The Odds API ------------------------------------------------------------
# Required for live betting lines factor. Free key at https://the-odds-api.com/
# If absent, the betting lines factor is skipped gracefully.
ODDS_API_KEY=

# --- Winner mode: factor weights ---------------------------------------------
# Engine normalises these so they don't need to sum to 1.0 — just set relative
# importance. Set a factor to 0.0 to disable it entirely in winner mode.
WEIGHT_FORM=
WEIGHT_ATS_FORM=
WEIGHT_REST_ADVANTAGE=
WEIGHT_BETTING_LINES=
WEIGHT_COACHING_MATCHUP=
WEIGHT_WEATHER=

# --- Cover mode: factor weights ----------------------------------------------
# Independent weight profile — cover mode can enable factors winner mode ignores.
# All 12 cover factors; new PBP/market factors default to 0.0 until optimised.
COVER_WEIGHT_FORM=
COVER_WEIGHT_ATS_FORM=
COVER_WEIGHT_REST_ADVANTAGE=
COVER_WEIGHT_BETTING_LINES=
COVER_WEIGHT_COACHING_MATCHUP=
COVER_WEIGHT_WEATHER=
COVER_WEIGHT_PYTHAGOREAN=
COVER_WEIGHT_EPA_DIFFERENTIAL=
COVER_WEIGHT_SUCCESS_RATE=
COVER_WEIGHT_TURNOVER_REGRESSION=
COVER_WEIGHT_GAME_SCRIPT=
COVER_WEIGHT_MARKET_SIGNALS=

# --- Winner margin calibration -----------------------------------------------
# Output of optimise_weights.py — informational; not used directly by the engine.
# predicted_margin = MARGIN_SLOPE * weighted_sum + MARGIN_INTERCEPT
MARGIN_SLOPE=
MARGIN_INTERCEPT=

# --- Cover margin calibration ------------------------------------------------
# Output of optimise_cover_weights.py — used by predict_cover(), backtest, and APIs.
# Calibrated against the 12-factor cover model. Falls back to MARGIN_SLOPE/INTERCEPT if unset.
# Run validation/optimise_cover_weights.py at end of season to get updated values.
COVER_MARGIN_SLOPE=
COVER_MARGIN_INTERCEPT=

# --- Confidence clamping -----------------------------------------------------
# Floor prevents extremely low-confidence picks from appearing.
# Ceiling prevents overconfident picks — set below 100 for caution.
CONFIDENCE_FLOOR=
CONFIDENCE_CEILING=

# --- Cover edge threshold ----------------------------------------------------
# Minimum confidence for a pick to receive the EDGE badge in the UI.
# Default in code is 50 (shows all picks); set higher to filter to conviction picks.
COVER_EDGE_THRESHOLD=

# --- Factor tuning -----------------------------------------------------------
# Lookback windows and decay rates for each sub-signal.
RECENT_FORM_GAMES=             # W/L form lookback window
RECENT_FORM_DECAY=             # Geometric decay per game back (shared across form sub-factors)
ATS_FORM_GAMES=                # ATS cover rate lookback window (games with spread data)
SCORING_DIFFERENTIAL_GAMES=    # Score differential lookback window
NYPP_GAMES=                    # Net Yards Per Play lookback window
NYPP_SANYPP_THRESHOLD_WEEK=    # Week at/after which schedule-adjusted NYPP correction applies
COACHING_MIN_GAMES=            # Min games required before a coaching sub-signal is trusted
WEATHER_MIN_GAMES=             # Min games in weather category before full confidence

# --- Scheduler ---------------------------------------------------------------
# All times are US Eastern (ET). Jobs run Mon/Thu/Sat/Sun to refresh data.
# Defaults (set in code): Mon 23:00, Thu 10:00, Sat 10:00, Sun 07:00.
SCHEDULER_MONDAY_HOUR=
SCHEDULER_MONDAY_MINUTE=
SCHEDULER_THURSDAY_HOUR=
SCHEDULER_THURSDAY_MINUTE=
SCHEDULER_SATURDAY_HOUR=
SCHEDULER_SATURDAY_MINUTE=
SCHEDULER_SUNDAY_HOUR=
SCHEDULER_SUNDAY_MINUTE=

# --- Authentication ----------------------------------------------------------
# Required for EC2 deployment. Use AUTH_DISABLED=true for local dev instead.
#
# Generate a password hash (run once, store result here):
#   python3 -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('yourpassword'))"
# Generate a secret key:
#   openssl rand -hex 32
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Set to true to bypass all auth checks (local dev only — never set on EC2).
AUTH_DISABLED=true
